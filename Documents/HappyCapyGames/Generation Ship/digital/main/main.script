-- Boot script. Determines host vs client role and wires up Steam networking.
-- Steam P2P send/receive calls are marked with -- STEAM: comments.

local C        = require("game.constants")
local host     = require("net.host")
local client   = require("net.client")
local protocol = require("net.protocol")

local IS_HOST = false  -- set during lobby

-- ─── Defold lifecycle ────────────────────────────────────────────────────────

function init(self)
	math.randomseed(os.time())
	-- STEAM: initialise steamworks, create or join lobby
end

function update(self, dt)
	-- STEAM: poll for incoming P2P messages
